<%- include('../partials/header') %>

    <div class="max-w-2xl mx-auto">
        <div class="mb-6">
            <a href="/pembelian" class="text-sm text-slate-500 hover:text-slate-700">
                ← Kembali ke Pembelian
            </a>
        </div>

        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 bg-slate-50">
                <h2 class="font-semibold text-slate-800">Form Tambah Pembelian</h2>
            </div>
            <form method="POST" action="/pembelian" class="px-6 py-6 space-y-5">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Nama Pembeli</label>
                    <input type="text" name="nama_pembeli" required placeholder="Contoh: Budi Santoso"
                        class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Produk</label>
                    <select name="produk_id" id="produkSelect" required onchange="updateInfo()"
                        class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                        <option value="">-- Pilih Produk --</option>
                        <% produk.forEach(p=> { %>
                            <option value="<%= p.id %>" data-harga="<%= p.harga %>" data-stock="<%= p.jumlah_stock %>">
                                <%= p.nama_produk %> — Rp <%= Number(p.harga).toLocaleString('id-ID') %> (Stock: <%=
                                            p.jumlah_stock %>)
                            </option>
                            <% }) %>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Jumlah</label>
                    <input type="number" name="jumlah" id="jumlahInput" required min="1" placeholder="1"
                        onchange="updateTotal()"
                        class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                </div>

                <div id="totalBox" class="hidden bg-emerald-50 border border-emerald-100 rounded-lg px-4 py-3">
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-slate-600">Total Harga:</span>
                        <span class="text-lg font-bold text-emerald-700" id="totalHarga">Rp 0</span>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Catatan (opsional)</label>
                    <textarea name="catatan" rows="3" placeholder="Catatan tambahan..."
                        class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none"></textarea>
                </div>

                <div class="flex gap-3 pt-2">
                    <a href="/pembelian"
                        class="flex-1 text-center border border-slate-200 text-slate-600 px-4 py-2.5 rounded-lg text-sm font-medium">
                        Batal
                    </a>
                    <button type="submit"
                        class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2.5 rounded-lg text-sm font-medium">
                        Simpan Pembelian
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function updateInfo() {
            const sel = document.getElementById('produkSelect');
            const opt = sel.options[sel.selectedIndex];
            if (opt.value) {
                document.getElementById('jumlahInput').max = opt.dataset.stock;
                updateTotal();
            }
        }

        function updateTotal() {
            const sel = document.getElementById('produkSelect');
            const opt = sel.options[sel.selectedIndex];
            const jumlah = Number(document.getElementById('jumlahInput').value);
            const totalBox = document.getElementById('totalBox');
            if (opt.value && jumlah > 0) {
                const total = Number(opt.dataset.harga) * jumlah;
                document.getElementById('totalHarga').textContent = 'Rp ' + total.toLocaleString('id-ID');
                totalBox.classList.remove('hidden');
            }
        }
    </script>

    <%- include('../partials/footer') %>