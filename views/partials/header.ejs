<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= title %> — AdminToko
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>

<body class="bg-slate-50 font-sans min-h-screen">

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <aside class="w-64 bg-indigo-700 text-white flex flex-col fixed inset-y-0 left-0">
            <div class="px-6 py-5 border-b border-indigo-600">
                <p class="font-bold">AdminToko</p>
                <p class="text-xs text-indigo-200">Management System</p>
            </div>
            <nav class="flex-1 px-4 py-5 space-y-1">
                <a href="/pembelian"
                    class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-indigo-200 hover:bg-white/10 hover:text-white">
                    <i class="fa-solid fa-cart-shopping"></i> Pembelian
                </a>
                <a href="/produk"
                    class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-indigo-200 hover:bg-white/10 hover:text-white">
                    <i class="fa-solid fa-box"></i> Produk
                </a>
                <a href="/stock"
                    class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-indigo-200 hover:bg-white/10 hover:text-white">
                    <i class="fa-solid fa-warehouse"></i> Stock
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 ml-64 flex flex-col min-h-screen overflow-y-auto">
            <header class="bg-white border-b border-slate-200 px-8 py-4">
                <h1 class="text-lg font-semibold text-slate-800">
                    <%= title %>
                </h1>
            </header>
            <main class="flex-1 px-8 py-6">